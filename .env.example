# ----------------------------------------------------------------------
# ExpressIt Studios — environment variables
# Copy this file to .env.local and fill in real values for local development.
# .env.local is git-ignored. Production values are set in the Vercel dashboard.
# ----------------------------------------------------------------------

# Stripe — Dashboard → Developers → API keys
# Use TEST keys for local development (start with sk_test_ / pk_test_).
# Use LIVE keys only in Vercel production env.
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook signing secret (Phase 2 — order tracking)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public site URL. Used for Stripe success/cancel redirects and absolute image URLs.
# Locally: http://localhost:3000
# Production: https://expressitstudios.com (set in Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Dashboard → Settings → API
# Project URL is public. Publishable key is safe in client code (protected by RLS).
# Secret key bypasses RLS — server-side only, never in NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Resend — powers /api/contact (and future order status emails).
# Domain expressitstudios.com is verified in Resend; sends from noreply@expressitstudios.com.
# Dashboard → API Keys → create one with Sending access scoped to expressitstudios.com.
RESEND_API_KEY=re_replace_me

# Admin dashboard (/admin) — HTTP Basic Auth credentials. The middleware
# (src/middleware.ts) gates /admin and /api/admin/* with these. Set a strong
# password; it's sent on every admin request.
ADMIN_USER=alex
ADMIN_PASSWORD=replace_me

# Legacy — unused. /admin auth moved to HTTP Basic Auth (ADMIN_USER/ADMIN_PASSWORD).
# Kept here only as a reminder to remove the var from Vercel.
ADMIN_EMAILS=alex@expressitstudios.com
